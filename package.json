{
  "name": "gridcoin-stamp-action",
  "version": "0.0.0",
  "private": true,
  "description": "GitHub Action to timestamp release assets on the Gridcoin blockchain via stamp.gridcoin.club",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/index.ts -o dist --source-map --license licenses.txt",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "all": "npm run typecheck && npm test && npm run build"
  },
  "keywords": [
    "github-action",
    "gridcoin",
    "blockchain",
    "timestamp",
    "notarize"
  ],
  "author": "gridcat",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.0",
    "@vercel/ncc": "^0.38.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.0"
  }
}
